---
import Base from '../layouts/Base.astro';
---
<Base title="::: Blueroom ::: Music : Art : Video : Home Page">

<!--
  Homepage of blue-room.it — April 2006 snapshot.
  Original structure: 4-row × 3-column table, 824px wide, centered.
  Each nav cell contains a Flash animation (served via Ruffle) + a label image.
  Bottom-right cell: photo of the current month's programme (mesemarzo.jpg).

  SWF → cell mapping (from original index.htm):
    1bis.swf  → programma
    1.swf     → archivio
    99.swf    → about us
    6.swf     → musica
    7.swf     → video
    8.swf     → art
    3.swf     → gallery
    4.swf     → contact
    navigazionepiccola.swf → top-right nav bar (237×32)
-->

<table width="824" border="0" align="center" cellpadding="2" cellspacing="2">

  <!-- row 1: logo / navigation bar -->
  <tr align="center" valign="middle">
    <td>&nbsp;</td>
    <td>&nbsp;</td>
    <td align="right">
      <embed src="/flash/navigazionepiccola.swf"
             width="237" height="32"
             type="application/x-shockwave-flash"
             quality="high">
    </td>
  </tr>

  <!-- row 2: programma | archivio | about us -->
  <tr align="right" valign="middle">
    <td class="quadro">
      <div class="flashhp">
        <embed src="/flash/quadriflash/1bis.swf"
               width="266" height="100"
               type="application/x-shockwave-flash"
               quality="high">
      </div>
      <br><br>
      <a href="/html/programma/marzo/marzomusica.htm" class="label-nav">programma</a>
    </td>
    <td class="quadro">
      <div class="flashhp">
        <embed src="/flash/quadriflash/1.swf"
               width="266" height="100"
               type="application/x-shockwave-flash"
               quality="high">
      </div>
      <br><br>
      <a href="/html/programma/archivio.htm" class="label-nav">archivio</a>
    </td>
    <td class="quadro">
      <div class="flashhp">
        <embed src="/flash/quadriflash/1bis.swf"
               width="266" height="100"
               type="application/x-shockwave-flash"
               quality="high">
      </div>
      <br><br>
      <a href="/html/aboutus.htm" class="label-nav">about us</a>
    </td>
  </tr>

  <!-- row 3: musica | video | art -->
  <tr align="right" valign="middle">
    <td class="quadro">
      <div class="flashhp">
        <embed src="/flash/quadriflash/6.swf"
               width="266" height="100"
               type="application/x-shockwave-flash"
               quality="high">
      </div>
      <br><br>
      <a href="/html/musica.htm" class="label-nav">musica</a>
    </td>
    <td class="quadro">
      <div class="flashhp">
        <embed src="/flash/quadriflash/7.swf"
               width="266" height="100"
               type="application/x-shockwave-flash"
               quality="high">
      </div>
      <br><br>
      <a href="/html/video.htm" class="label-nav">video</a>
    </td>
    <td class="quadro">
      <div class="flashhp">
        <embed src="/flash/quadriflash/8.swf"
               width="266" height="100"
               type="application/x-shockwave-flash"
               quality="high">
      </div>
      <br><br>
      <a href="/html/art/3500cm.htm" class="label-nav">art</a>
    </td>
  </tr>

  <!-- row 4: gallery | contact | mese corrente (photo) -->
  <tr align="right" valign="middle">
    <td class="quadro">
      <div class="flashhp">
        <embed src="/flash/quadriflash/3.swf"
               width="266" height="100"
               type="application/x-shockwave-flash"
               quality="high">
      </div>
      <br><br>
      <a href="/html/gallery/gallery.htm" class="label-nav">gallery</a>
    </td>
    <td class="quadro">
      <div class="flashhp">
        <embed src="/flash/quadriflash/4.swf"
               width="266" height="100"
               type="application/x-shockwave-flash"
               quality="high">
      </div>
      <br><br>
      <a href="/html/contact.htm" class="label-nav">contact</a>
    </td>
    <!-- not Flash: this is the month's editorial photo, links to current programme -->
    <td class="quadro" align="center">
      <a href="/html/programma/marzo/marzomusica.htm">
        <img src="/images/archivio/mesemarzo.jpg" width="266" height="177" border="0" alt="blueroom marzo">
      </a>
    </td>
  </tr>

</table>

</Base>
